---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE } from '../consts';
---

<Layout title={SITE_TITLE} description="Simple, privacy-respecting iOS apps designed to be genuinely useful.">

  <!-- Hero -->
  <section class="hero">
    <h1>We build apps that are, well... simply useful</h1>
    <p class="tagline">
      Simply Useful Apps builds focused iOS apps with simple pricing, no subscriptions, no ads,
      and privacy-respecting analytics.
    </p>
  </section>

  <!-- Featured App -->
  <h2>Our Apps</h2>
  <section class="app-card">
	<h3><span aria-hidden="true">🖼️</span> Galerie</h3>
    <p class="app-subtitle">A simple and useful digital photo frame for your iPhone and iPad.</p>
    <p>
      Turn your device into a living photo frame. Galerie displays your photo library albums
      as a smooth, elegant slideshow — perfect for a nightstand, desk, or anywhere
      you want your memories on display.
    </p>
    <div class="badge-area">
      <span class="coming-soon">Coming soon to the App Store</span>
      <!-- When live, replace the line above with:
      <a href="YOUR_APP_STORE_LINK">
        <img src="/images/app-store-badge.svg" alt="Download on the App Store" width="160" />
      </a>
      -->
    </div>
  </section>

  <!-- Privacy Trust Statement -->
  <section class="trust">
    <h2><span aria-hidden="true">🔒</span> Private by default</h2>
    <p>
      No ads. No account required. No selling your data. We use limited,
      privacy-focused analytics to make the app better, and those analytics do
      not include personally identifiable information.
    </p>
    <a href="/privacy-policy">Privacy Policy →</a>
  </section>

</Layout>

<style>
  .hero {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .hero h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1.15rem;
    max-width: 38rem;
    margin: 0 auto;
    opacity: 0.8;
  }

  .app-card {
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 0.75rem;
    padding: 2rem;
    margin: 2.5rem 0;
  }

  .app-card h2 {
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
  }

  .app-subtitle {
    font-size: 1.05rem;
    opacity: 0.75;
    margin-bottom: 1rem;
  }

  .badge-area {
    margin-top: 1.5rem;
  }

  .coming-soon {
    display: inline-block;
    background: var(--accent, #4f46e5);
    color: #fff;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .trust {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border, #e2e8f0);
    margin-top: 1rem;
  }

  .trust h2 {
    margin-bottom: 0.75rem;
  }

  .trust a {
    display: inline-block;
    margin-top: 0.75rem;
    font-weight: 500;
    text-decoration: underline;
  }
</style>